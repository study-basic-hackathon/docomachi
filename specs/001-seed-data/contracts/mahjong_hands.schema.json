{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MahjongHandsSeed",
  "description": "Seed data for mahjong quiz: array of problems (doc/seed/mahjong_hands.json)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["tiles", "winningTiles", "difficulty"],
    "properties": {
      "id": { "type": "string", "description": "Unique identifier for the problem" },
      "tiles": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 13,
        "maxItems": 13,
        "description": "13 tile codes (TileCode)"
      },
      "winningTiles": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1,
        "description": "Correct waiting tile(s)"
      },
      "difficulty": {
        "type": "string",
        "enum": ["low", "middle", "high"],
        "description": "Difficulty level, auto-assigned"
      }
    }
  }
}
